              "});",
              "",
              "pm.test(\"Response is an object\", function () {",
              "    pm.expect(body).to.be.an(\"object\");",
              "});",
              "",
              "pm.test(\"Response has id property\", function () {",
              "    pm.expect(body).to.have.property(\"id\");",
              "});",
              "",
              "pm.test(\"Title matches request\", function () {",
              "    pm.expect(body.title).to.equal(\"My test post\");",
              "});",
              "",
              "pm.test(\"userId is a number\", function () {",
              "    pm.expect(body.userId).to.be.a(\"number\");",
              "});",
              "",
              "// Bonus - save postId",
              "pm.collectionVariables.set(\"postId\", body.id);",
              "console.log(\"Saved postId:\", body.id);",
              "",
